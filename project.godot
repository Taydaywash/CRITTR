config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="CRITTR"
run/main_scene="uid://c5tai0s4khvnm"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
config/icon="res://Assets/Misc/icon.svg"

[audio]

buses/default_bus_layout="uid://kmjjtd27eflc"

[autoload]

SaveLoadManager="*res://Global Scripts/save_load_manager.gd"
EventController="*uid://3n7xlwd6ef2b"
GameController="*uid://b5kigqng4mpw3"
Dialog="*uid://lgbu1cs8kh44"

[display]

window/size/resizable=false
window/size/minimize_disabled=true
window/size/maximize_disabled=true
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://Assets/": "teal",
"res://Custom Classes/": "pink",
"res://Global Scripts/": "blue",
"res://Scenes/": "yellow",
"res://Tools/": "purple"
}

