[sub_resource type="GDScript" id="GDScript_ssr24"]
resource_name = "DiveTutorialText"
script/source = "extends SingleViewText

var fade_out = false

var id : String
func _ready() -> void:
	id = \"%s\" % [name]
	if id in GameController.game_state.viewed_tutorial_text:
		queue_free()

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(\"dive\"):
		fade_out = true
func _process(delta: float) -> void:
	if fade_out:
		modulate.a = lerpf(modulate.a,0.0,delta*10)
		if modulate.a < 0.01:
			EventController.emit_signal(\"tutorial_text_viewed\",id)
			queue_free()
"

